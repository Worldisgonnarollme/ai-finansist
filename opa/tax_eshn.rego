package tax.eshn

import rego.v1

############################################
# ЮРИДИЧЕСКАЯ ГРАНИЦА ОТВЕТСТВЕННОСТИ
#
# Этот пакет ВАЛИДИРУЕТ допустимость состояния (имеем ли мы право считать
# субъекта/операцию подпадающей под ЕСХН), но НЕ СЧИТАЕТ налог и НЕ
# ПОДБИРАЕТ процент (0–6%, региональный — вне scope policy). Расчёт —
# отдельный слой с отдельной ответственностью, вне OPA. Любая
# неопределённость трактуется как НЕсоответствие (compliant: false), а не
# как "требует ручной проверки". Запрещены умножение суммы операции на
# процент и любые числовые налоговые поля (кроме пороговых значений
# лимитов, фиксированных законом). Соблюдение проверяется CI-гардом
# (.github/workflows/policy-no-calc.yml).
############################################

############################################
# ELIGIBILITY — ДОЛЯ СЕЛЬХОЗДОХОДА ≥ 70%
#
# Основание: ст. 346.2 НК РФ.
############################################

default eligibility := {
  "compliant": false,
  "reason": "Нет подтверждения, что доля дохода от сельскохозяйственной деятельности за налоговый период составляет не менее 70%",
  "legal_basis": [],
}

eligibility := {
  "compliant": true,
  "reason": "Доля дохода от сельскохозяйственной деятельности за налоговый период составляет не менее 70%",
  "legal_basis": ["НК РФ ст. 346.2"],
} if {
  input.user.tax_mode == "ESHN"
  input.context.eshn.agri_income_share >= 0.70
}

############################################
# INCOME — КВАЛИФИКАЦИЯ КАК СЕЛЬХОЗЯЙСТВЕННЫЙ ДОХОД
#
# Вопрос здесь не "облагается ли доход" (под ЕСХН облагается весь доход,
# не только сельхозяйственный), а "засчитывается ли он в долю 70%" —
# это требует подтверждения собственного производства (ст. 346.2 НК РФ),
# а не факта перепродажи покупной продукции.
############################################

default income := {
  "compliant": false,
  "reason": "Нет подтверждения, что доход относится к собственному производству (в т.ч. первичной переработке) сельхозпродукции — не засчитывается в долю 70%",
  "legal_basis": [],
}

income := {
  "compliant": true,
  "reason": "Доход подтверждён как доход от собственного производства (или первичной переработки) сельхозпродукции",
  "legal_basis": ["НК РФ ст. 346.2"],
} if {
  input.user.tax_mode == "ESHN"
  input.transaction.direction == "income"
  input.transaction.is_own_production == true
}

############################################
# EXPENSE — ЗАКРЫТЫЙ ПЕРЕЧЕНЬ СТ. 346.5 НК РФ
############################################

default expense := {
  "compliant": false,
  "reason": "Нет подтверждения, что расход входит в закрытый перечень ст. 346.5 НК РФ",
  "legal_basis": [],
}

expense := {
  "compliant": true,
  "reason": "Расход входит в закрытый перечень расходов, признаваемых при ЕСХН",
  "legal_basis": ["НК РФ ст. 346.5"],
} if {
  input.user.tax_mode == "ESHN"
  input.transaction.direction == "expense"
  input.transaction.included_under_art_346_5 == true
}

############################################
# VAT — ПЛАТЕЛЬЩИК ЕСХН ЯВЛЯЕТСЯ ПЛАТЕЛЬЩИКОМ НДС ПО УМОЛЧАНИЮ
#
# В отличие от eligibility/income/expense, default-состояние здесь —
# действующая обязанность по НДС (это нормальное состояние режима с 2019
# года, а не неопределённость). Освобождение — это исключение, которое
# должно быть явно заявлено И подтверждено пороговым доходом предыдущего
# года; непроверяемое заявление не отменяет действующую обязанность.
############################################

default vat := {
  "compliant": true,
  "reason": "Плательщик ЕСХН признаётся плательщиком НДС по умолчанию, пока освобождение не заявлено и не подтверждено",
  "legal_basis": ["НК РФ ст. 145"],
}

vat := {
  "compliant": true,
  "reason": "Освобождение от НДС подтверждено: доход без НДС за предыдущий календарный год не превышает установленный порог",
  "legal_basis": ["НК РФ ст. 145 п. 1"],
} if {
  input.context.eshn.vat_exemption_claimed == true
  input.context.eshn.prior_year_income_excl_vat <= 60000000
}

vat := {
  "compliant": false,
  "reason": "Освобождение от НДС заявлено, но доход без НДС за предыдущий календарный год превышает установленный порог — заявление не имеет правового основания",
  "legal_basis": ["НК РФ ст. 145 п. 1"],
} if {
  input.context.eshn.vat_exemption_claimed == true
  input.context.eshn.prior_year_income_excl_vat > 60000000
}

############################################
# AGGREGATED DECISION
############################################

default decision := {"compliant": false}

decision := {
  "eligibility": eligibility,
  "income": income,
  "vat": vat,
  "compliant": true,
} if {
  input.transaction.direction == "income"
  eligibility.compliant == true
  income.compliant == true
  vat.compliant == true
}

decision := {
  "eligibility": eligibility,
  "expense": expense,
  "vat": vat,
  "compliant": true,
} if {
  input.transaction.direction == "expense"
  eligibility.compliant == true
  expense.compliant == true
  vat.compliant == true
}
