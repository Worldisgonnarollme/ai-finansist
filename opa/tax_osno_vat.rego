package tax.osno.vat

import rego.v1

############################################
# ЮРИДИЧЕСКАЯ ГРАНИЦА ОТВЕТСТВЕННОСТИ
#
# Этот пакет КВАЛИФИЦИРУЕТ операцию как объект обложения НДС (ст. 146 НК
# РФ), но НЕ СЧИТАЕТ сумму НДС и НЕ ПОДБИРАЕТ процент (0/10/20%). Расчёт
# суммы налога — отдельный слой с отдельной ответственностью, вне OPA.
# Запрещены умножение суммы операции на процент и любые числовые
# налоговые поля. Соблюдение проверяется CI-гардом
# (.github/workflows/opa-osno-guard.yml).
############################################

############################################
# ANTI-HALLUCINATION DEFAULT
############################################

default result := {
  "vat_object": false,
  "needs_review": true,
  "reason": "Невозможно однозначно определить объект обложения НДС",
  "legal_basis": [],
  "invoice_documented": false,
  "invoice_legal_basis": []
}

############################################
# VAT OBJECT DETECTION (NO CALCULATION)
#
# Объект обложения НДС (ст. 146 НК РФ) определяется фактом реализации,
# а не наличием счёта-фактуры — обязанность его выставить (ст. 168/169
# НК РФ) это отдельный документальный вопрос, не условие возникновения
# объекта налогообложения. Поэтому он вынесен в отдельное поле
# invoice_documented с собственным legal_basis, а не в условие vat_object.
############################################

result := {
  "vat_object": true,
  "needs_review": false,
  "reason": "Реализация товаров, работ или услуг признаётся объектом обложения НДС",
  "legal_basis": [
    "НК РФ ст. 146"
  ],
  "invoice_documented": input.transaction.has_vat_invoice,
  "invoice_legal_basis": [
    "НК РФ ст. 168",
    "НК РФ ст. 169"
  ]
} if {
  input.user.tax_mode == "OSNO"
  input.transaction.direction == "income"
  input.transaction.vat_applicable == true
}
