package tax.npd

import rego.v1

############################################
# ЮРИДИЧЕСКАЯ ГРАНИЦА ОТВЕТСТВЕННОСТИ
#
# Этот пакет ВАЛИДИРУЕТ допустимость состояния (имеем ли мы право считать
# субъекта применяющим НПД), но НЕ ПЕРЕОПРЕДЕЛЯЕТ и НЕ ДУБЛИРУЕТ
# квалификацию конкретного дохода — она остаётся в tax.policy (ст. 8
# 422-ФЗ, ставки 4%/6%), единственном источнике истины для этого вопроса.
# Любая неопределённость в праве на режим трактуется как НЕсоответствие
# (compliant: false), а не как "требует ручной проверки" — превышение
# лимита/наличие работников/перепродажа структурно ИСКЛЮЧАЮТ НПД, это не
# вопрос неполноты данных. Запрещены умножение суммы операции на процент
# и любые числовые налоговые поля (кроме порогового значения лимита,
# фиксированного законом). Соблюдение проверяется CI-гардом
# (.github/workflows/opa-policy-guard.yml).
############################################

############################################
# ELIGIBILITY — ПРАВО ПРИМЕНЯТЬ НПД
#
# Основание: ст. 4 ч. 2 422-ФЗ от 27.11.2018 "О проведении эксперимента по
# установлению специального налогового режима «Налог на профессиональный
# доход»" — закрытый перечень условий, исключающих применение режима
# (наёмные работники, перепродажа, подакцизные/маркированные товары,
# добыча/реализация полезных ископаемых, агентские/комиссионные схемы без
# исключения для доставки с ККТ продавца, совмещение с другим режимом по
# той же деятельности), и ст. 4 ч. 2 п. 8 — лимит дохода 2,4 млн ₽ в год.
############################################

default eligibility := {
  "compliant": false,
  "reason": "Нет достаточных оснований подтвердить право на применение НПД",
  "legal_basis": [],
}

eligibility := {
  "compliant": true,
  "reason": "Подтверждены лимит дохода, отсутствие наёмных работников, перепродажи, подакцизных/маркированных товаров, добычи полезных ископаемых, агентских схем без исключения и совмещения с другим режимом по той же деятельности",
  "legal_basis": ["Федеральный закон от 27.11.2018 № 422-ФЗ ст. 4 ч. 2"],
} if {
  input.user.tax_mode == "NPD"
  input.context.npd.annual_income <= 2400000
  input.context.npd.has_employees == false
  input.context.npd.is_resale == false
  input.context.npd.sells_excisable_or_marked_goods == false
  input.context.npd.mines_or_sells_minerals == false
  input.context.npd.agent_scheme_without_exception == false
  input.context.npd.combines_with_other_regime_same_activity == false
}

############################################
# EXPENSE — НПД НЕ ИМЕЕТ КАТЕГОРИИ "РАСХОД"
#
# Налоговая база НПД — доход целиком (ст. 8 422-ФЗ), без уменьшения на
# расходы. Это уверенный факт, а не неопределённость.
############################################

default expense := {
  "compliant": false,
  "reason": "Расходы не являются налоговой категорией для НПД — налоговая база НПД формируется по доходу целиком",
  "legal_basis": ["Федеральный закон от 27.11.2018 № 422-ФЗ ст. 8"],
}

############################################
# AGGREGATED DECISION
#
# Income-классификация (ставки 4%/6%, needs_review) остаётся единственно
# в tax.policy — здесь не дублируется. Eligibility действует как
# дополнительный гейт: если право на НПД не подтверждено, итоговое
# решение не может быть уверенным, какой бы ни была классификация
# дохода — операция структурно не может облагаться НПД.
############################################

default decision := {
  "needs_review": true,
  "reason": "Нет достаточных оснований подтвердить право на применение НПД",
  "legal_basis": [],
}

decision := data.tax.policy.result if {
  input.user.tax_mode == "NPD"
  input.transaction.direction == "income"
  eligibility.compliant == true
}

# Право на НПД явно не подтверждено (например, превышен лимит дохода или
# подтверждены наёмные работники) — даже уверенная классификация по
# ст. 8 422-ФЗ не может быть автоматически применена: операция требует
# переквалификации по другому режиму, чего этот пакет не делает.
decision := {
  "eligibility": eligibility,
  "needs_review": true,
  "reason": eligibility.reason,
  "legal_basis": eligibility.legal_basis,
} if {
  input.user.tax_mode == "NPD"
  input.transaction.direction == "income"
  eligibility.compliant == false
}

decision := {
  "eligibility": eligibility,
  "expense": expense,
  "needs_review": false,
  "reason": expense.reason,
  "legal_basis": expense.legal_basis,
} if {
  input.user.tax_mode == "NPD"
  input.transaction.direction == "expense"
}
